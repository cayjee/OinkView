# OinkView — Chemins vers votre installation Snort 3
# Modifier ces chemins si votre Snort n'est pas installé aux emplacements par défaut.
# Installation standard Snort 3 : aucune modification nécessaire.

# Dossier des règles (contient local.rules et les règles communautaires)
SNORT_RULES_DIR=/etc/snort/rules

# Dossier de configuration (contient snort.lua)
SNORT_CONFIG_DIR=/usr/local/etc/snort

# Binaire Snort (pour la validation de config et le test PCAP)
SNORT_BIN=/usr/local/bin/snort

# Dossier des logs (contient alert_fast.txt ou alert_json.txt)
SNORT_LOG_DIR=/var/log/snort
