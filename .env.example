# OinkView — Configuration des chemins Snort
# Copier ce fichier en .env et adapter les chemins à votre installation
#
#   cp .env.example .env
#   nano .env

# Dossier des règles Snort (contient local.rules et les règles communautaires)
SNORT_RULES_DIR=/etc/snort/rules

# Dossier de configuration Snort (contient snort.lua)
SNORT_CONFIG_DIR=/usr/local/etc/snort

# Binaire Snort (pour validation de config et test PCAP)
SNORT_BIN=/usr/local/bin/snort

# Dossier des logs Snort (contient alert_fast.txt ou alert_json.txt)
SNORT_LOG_DIR=/var/log/snort
